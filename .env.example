# =============================================================================
# Java Microservices Reference — Environment Variables
# =============================================================================
# Copy this file to .env before running docker compose:
#   cp .env.example .env
#
# All defaults work for local development. Change only what you need.
# NEVER commit the actual .env file (it is in .gitignore).

# --- Database ----------------------------------------------------------------
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments
POSTGRES_DB=payments

# --- JWT (HS256) -------------------------------------------------------------
# Minimum 32 bytes. Used by payment-service to sign and verify tokens.
#
# To generate a strong secret:
#   openssl rand -hex 32
#
# The scripts/smoke-test.sh uses this value to mint tokens locally via openssl.
JWT_SECRET=dev-secret-change-in-prod-min-32-bytes-xxxx

# --- Kafka -------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- OpenTelemetry -----------------------------------------------------------
# Endpoint for the OTel Collector (gRPC).
# Traces and metrics are exported here by both services.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp

# --- Host ports --------------------------------------------------------------
# Override these to avoid conflicts with other local services.
# Internal container ports are NOT affected by these variables.
PORT_PAYMENT=18081
PORT_NOTIFICATION=18082
POSTGRES_PORT=15432
PORT_REDIS=16379
PORT_ZOOKEEPER=12181
PORT_KAFKA=19092
PORT_KAFKA_EXTERNAL=29092
PORT_SCHEMA_REGISTRY=18085
PORT_KAFDROP=19000
PORT_PROMETHEUS=19090
PORT_GRAFANA=13000
PORT_OTEL_GRPC=14317
PORT_OTEL_HTTP=14318
PORT_OTEL_METRICS=18889

# --- Docker build platform ---------------------------------------------------
# Controls the target platform for payment-service and notification-service images.
#   - Apple Silicon (M1/M2/M3/M4): linux/arm64  (default)
#   - Intel / AMD / CI x86_64:     linux/amd64
#
# Fallback: if a Java SIGILL occurs during `docker build` on Apple Silicon,
# try DOCKER_PLATFORM=linux/amd64 (runs via emulation; slower but stable).
DOCKER_PLATFORM=linux/arm64

# --- Kafdrop platform --------------------------------------------------------
# Kafdrop upstream image (obsidiandynamics/kafdrop) only publishes linux/amd64.
# On Apple Silicon it runs via emulation — functional but slower.
# If/when an arm64 tag ships, switch to linux/arm64.
KAFDROP_PLATFORM=linux/amd64
