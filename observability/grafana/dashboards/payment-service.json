{
  "uid": "payment-service",
  "title": "Payment Service",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "current": { "value": "payment-service", "text": "payment-service" },
        "options": [
          { "value": "payment-service", "text": "payment-service" },
          { "value": "notification-service", "text": "notification-service" }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Payments Created (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "payments_created_total",
          "legendFormat": "created"
        }
      ]
    },
    {
      "id": 2,
      "title": "Payments Processed (by status)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "payments_processed_total",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Notifications Received (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "notifications_received_total",
          "legendFormat": "received"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"payment-service\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"payment-service\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"payment-service\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag_max{job=\"notification-service\"}",
          "legendFormat": "{{topic}} {{partition}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"payment-service\"}",
          "legendFormat": "heap used"
        },
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"notification-service\"}",
          "legendFormat": "notification heap used"
        }
      ]
    },
    {
      "id": 7,
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"payment-service\"}",
          "legendFormat": "payment-service"
        },
        {
          "expr": "process_cpu_usage{job=\"notification-service\"}",
          "legendFormat": "notification-service"
        }
      ]
    }
  ],
  "annotations": { "list": [] },
  "tags": ["payment-service", "observability"]
}
